# HuggingFace Spaces Configuration
# Copy this to your Learnverse .env.local (in project root)

# FreeEducationVision Space endpoint (update after deployment)
# Format: https://[YOUR_USERNAME]-[SPACE_NAME].hf.space/api/predict
NEXT_PUBLIC_TUTOR_ENDPOINT=https://freeeducationvision-learnverse-tutor.hf.space/api/predict

# Optional: HuggingFace API token (for private Spaces)
# Get from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
